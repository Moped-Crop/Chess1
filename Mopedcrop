<!DOCTYPE html>
<html>
<head>
<meta charset="UTF-8">
<title>Chess offline</title>
<style>
  body { display:flex; justify-content:center; align-items:center; height:100vh; background:#222; }
  #board { display:grid; grid-template-columns:repeat(8,60px); width:480px; }
  .cell { width:60px; height:60px; display:flex; justify-content:center; align-items:center; font-size:32px; cursor:pointer; }
  .white { background:#f0d9b5; }
  .black { background:#b58863; }
</style>
</head>
<body>

<div id="board"></div>

<script>
const board = document.getElementById("board");

const pieces = {
  r:"♜", n:"♞", b:"♝", q:"♛", k:"♚", p:"♟",
  R:"♖", N:"♘", B:"♗", Q:"♕", K:"♔", P:"♙"
};

let position = [
"rnbqkbnr",
"pppppppp",
"        ",
"        ",
"        ",
"        ",
"PPPPPPPP",
"RNBQKBNR"
];

let selected = null;

function draw(){
  board.innerHTML = "";

  for(let r=0;r<8;r++){
    for(let c=0;c<8;c++){
      let cell = document.createElement("div");
      cell.className = "cell " + ((r+c)%2 ? "black":"white");

      let piece = position[r][c];
      cell.innerText = pieces[piece] || "";

      cell.onclick = () => click(r,c);

      board.appendChild(cell);
    }
  }
}

function click(r,c){
  if(selected){
    position[r] = replaceChar(position[r], c, position[selected.r][selected.c]);
    position[selected.r] = replaceChar(position[selected.r], selected.c, " ");
    selected = null;
    draw();
  } else {
    if(position[r][c] !== " "){
      selected = {r,c};
    }
  }
}

function replaceChar(str, i, char){
  return str.substring(0,i) + char + str.substring(i+1);
}

draw();
</script>

</body>
</html>
